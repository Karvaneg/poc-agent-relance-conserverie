# =============================================================================
# Modele de configuration du POC agent-relance-conserverie.
#
# Copier ce fichier en `.env` puis renseigner les vraies valeurs :
#     cp .env.example .env
#
# Le fichier `.env` est ignore par Git (voir .gitignore) : il ne doit JAMAIS
# etre commite. Ne mettez aucun secret reel dans CE fichier (.env.example).
# =============================================================================

# --- Odoo (acces XML-RPC) ----------------------------------------------------
# URL de l'instance Odoo locale (cf. docker/docker-compose.yml -> port 8069).
ODOO_URL=http://localhost:8069

# Nom de la base creee dans Odoo (cf. POSTGRES_DB / database manager).
ODOO_DB=conserverie

# Identifiants du compte Odoo utilise par l'agent (lecture des factures).
# Par defaut, le compte administrateur cree a l'initialisation de la base.
ODOO_LOGIN=admin
ODOO_PASSWORD=admin

# --- Anthropic (API Claude) --------------------------------------------------
# Cle API Anthropic. Valeur ci-dessous FICTIVE : remplacer dans .env par la vraie cle.
# Sans cle Anthropic valide, l'agent Phase B ne peut PAS appeler Claude (il crashera).
# Generer une cle ici : https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Modele Claude utilise pour generer les messages de relance.
# claude-sonnet-4-6 : bon rapport cout / latence / qualite pour la redaction.
# (claude-opus-4-8 possible si la qualite prime pour la demo.)
CLAUDE_MODEL=claude-sonnet-4-6
